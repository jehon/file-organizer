    "version": "0.2.0",
    "configurations": [

        {
            "type": "node",
            "request": "launch",
            "name": "Launch jasmine",
            "program": "${workspaceFolder}/node_modules/.bin/jasmine",
            "args": [ "--config=test/unit/jasmine.json" ]
        },
        {
            "type": "node",
            "request": "launch",
            "name": "info",
            "program": "${workspaceFolder}/file-organizer/main.js",
            "args": [ "info", "test/data/canon.JPG" ]
        },
        {
            "type": "node",
            "request": "launch",
            "name": "run on 01-test-lib",
            "program": "${workspaceFolder}/file-organizer/main.js",
            "cwd": "${workspaceFolder}/tmp/01-test-lib.sh",
            "args": [ "-n" ]
        }
    ]
}