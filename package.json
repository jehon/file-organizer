{
  "name": "file-organizer",
  "version": "1.0.0",
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "eslint": "^5.1.0",
    "istanbul": "^0.4.5",
    "jasmine": "^3.2.0",
    "nyc": "^13.3.0",
    "opn-cli": "^4.0.0"
  },
  "scripts": {
    "clean": "rm -fr tmp target",
    "test": "npm run clean && npm run test-unit && npm run test-system",
    "view-cover": "opn target/unit-coverage/index.html",
    "test-system": "./test/system-test/all.sh"
    "test-unit": "jasmine --config=test/unit/jasmine.json",
    "test-unit-cover": "nyc jasmine --config=test/unit/jasmine.json",
  },
  "dependencies": {
    "ansi-escapes": "^3.1.0",
    "chalk": "^2.4.2",
    "colors": "^1.3.2",
    "fs-extra": "^7.0.1",
    "p-limit": "^2.2.0",
    "yargs": "^12.0.5"
  },
  "nyc": {
    "reporter": [
      "lcov",
      "text-summary"
    ],
    "temp-dir": "./tmp/coverage",
    "report-dir": "./target/unit-coverage"
  }
}
