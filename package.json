{
  "name": "file-organizer",
  "version": "1.0.0",
  "author": "",
  "license": "ISC",
  "dependencies": {
    "ansi-escapes": "4.2.1",
    "chalk": "2.4.2",
    "colors": "1.3.3",
    "fs-extra": "8.1.0",
    "p-limit": "2.2.1",
    "shell-exec": "1.0.2",
    "yargs": "14.0.0"
  },
  "devDependencies": {
    "depcheck": "0.8.3",
    "eslint": "6.2.1",
    "jasmine": "3.4.0"
  },
  "scripts": {
    "clean": "rm -fr tmp",
    "eslint": "eslint .",
    "test": "npm run clean && npm run test-unit && npm run test-system && npm run eslint && npm run depcheck",
    "test-unit": "jasmine --config=test/unit/jasmine.json",
    "test-system": "jasmine --config=test/system/jasmine.json",
    "depcheck": "depcheck"
  },
  "nyc": {
    "reporter": [
      "lcov",
      "text-summary"
    ],
    "temp-dir": "./tmp/coverage",
    "report-dir": "./tmp/unit-coverage"
  }
}
