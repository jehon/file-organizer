{
  "name": "file-organizer",
  "version": "1.0.0",
  "author": "",
  "license": "ISC",
  "dependencies": {
    "ansi-escapes": "4.2.1",
    "chalk": "2.4.2",
    "colors": "1.3.3",
    "command-exists": "1.2.8",
    "debug": "^4.1.1",
    "fs-extra": "8.1.0",
    "moment": "2.24.0",
    "moment-timezone": "0.5.26",
    "p-limit": "2.2.1",
    "shell-exec": "1.0.2",
    "tz-lookup": "6.1.24",
    "yargs": "14.0.0"
  },
  "devDependencies": {
    "current-git-branch": "1.1.0",
    "depcheck": "0.8.3",
    "eslint": "6.4.0",
    "jasmine": "3.4.0",
    "just-diff": "3.0.1"
  },
  "scripts": {
    "clean": "rm -fr tmp",
    "eslint": "eslint .",
    "test": "npm run clean && npm run test-unit && npm run test-system && npm run eslint && npm run depcheck",
    "test-unit": "jasmine --config=test/unit/jasmine.json",
    "test-system": "jasmine --config=test/system/jasmine.json",
    "depcheck": "depcheck"
  },
  "nyc": {
    "reporter": [
      "lcov",
      "text-summary"
    ],
    "temp-dir": "./tmp/coverage",
    "report-dir": "./tmp/unit-coverage"
  }
}
