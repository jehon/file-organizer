{
  "name": "file-organizer",
  "version": "1.0.0",
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "eslint": "5.15.1",
    "istanbul": "0.4.5",
    "jasmine": "3.3.1",
    "nyc": "13.3.0",
    "opn-cli": "4.0.0"
  },
  "scripts": {
    "clean": "rm -fr tmp target",
    "eslint": "eslint .",
    "test": "npm run clean && npm run eslint && npm run test-unit && npm run test-system",
    "view-cover": "opn target/unit-coverage/index.html",
    "test-unit": "jasmine --config=test/unit/jasmine.json",
    "test-unit-cover": "nyc jasmine --config=test/unit/jasmine.json",
    "test-system-old": "./test/system-test/all.sh",
    "test-system": "jasmine --config=test/system/jasmine.json"
  },
  "dependencies": {
    "ansi-escapes": "3.2.0",
    "chalk": "2.4.2",
    "colors": "1.3.3",
    "fs-extra": "7.0.1",
    "p-limit": "2.2.0",
    "shell-exec": "1.0.2",
    "yargs": "12.0.5"
  },
  "nyc": {
    "reporter": [
      "lcov",
      "text-summary"
    ],
    "temp-dir": "./tmp/coverage",
    "report-dir": "./target/unit-coverage"
  }
}
