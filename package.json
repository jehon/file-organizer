    "private": true,
    "author": "Jean Honlet",
    "license": "MIT",
    "repository": "https://github.com/jehon/file-organizer",
    "dependencies": {
        "chalk": "4.1.0",
        "colors": "1.4.0",
        "command-exists": "1.2.9",
        "css-inherit": "jehon/css-inherit",
        "debug": "4.2.0",
        "electron": "11.0.0-beta.20",
        "fs-extra": "9.0.1",
        "graceful-fs": "4.2.4",
        "is-interactive": "1.0.0",
        "moment": "2.29.1",
        "moment-timezone": "0.5.31",
        "p-limit": "3.0.2",
        "p-queue": "6.6.2",
        "shell-exec": "1.0.2",
        "tz-lookup": "6.1.25",
        "watch": "1.0.2",
        "yargs": "16.1.0"
    },
    "devDependencies": {
        "@types/jasmine": "3.6.1",
        "babel-eslint": "10.1.0",
        "current-git-branch": "1.1.0",
        "depcheck": "1.3.1",
        "eslint": "7.13.0",
        "eslint-plugin-jsdoc": "30.7.7",
        "jasmine": "3.6.3",
        "nyc": "15.1.0"
    },
    "scripts": {
        "demo": "electron ./demo.cjs",
        "start": "electron src/main.cjs",
