{
  "name": "file-organizer",
  "version": "1.0.0",
  "author": "",
  "license": "ISC",
  "dependencies": {
    "ansi-escapes": "4.2.1",
    "chalk": "2.4.2",
    "colors": "1.4.0",
    "command-exists": "1.2.8",
    "debug": "4.1.1",
    "fs-extra": "8.1.0",
    "graceful-fs": "4.2.2",
    "is-interactive": "1.0.0",
    "moment": "2.24.0",
    "moment-timezone": "0.5.27",
    "p-limit": "2.2.1",
    "p-queue": "6.2.0",
    "shell-exec": "1.0.2",
    "tz-lookup": "6.1.24",
    "yargs": "14.2.0"
  },
  "devDependencies": {
    "current-git-branch": "1.1.0",
    "depcheck": "0.8.4",
    "eslint": "6.6.0",
    "jasmine": "3.5.0"
  },
  "scripts": {
    "clean": "rm -fr tmp",
    "eslint": "eslint .",
    "test": "npm run --silent clean && npm run --silent test-unit && npm run --silent test-system",
    "style": "npm run --silent eslint && npm run --silent depcheck",
    "test-unit": "jasmine --config=test/unit/jasmine.json",
    "test-system": "jasmine --config=test/system/jasmine.json",
    "depcheck": "depcheck"
  },
  "nyc": {
    "reporter": [
      "lcov",
      "text-summary"
    ],
    "temp-dir": "./tmp/coverage",
    "report-dir": "./tmp/unit-coverage"
  }
}
