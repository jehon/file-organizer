{
  "name": "file-organizer",
  "version": "1.0.0",
  "private": true,
  "author": "Jean Honlet",
  "license": "MIT",
  "repository": "https://github.com/jehon/file-organizer",
  "dependencies": {
    "chalk": "4.1.0",
    "command-exists": "1.2.9",
    "css-inherit": "github:jehon/css-inherit",
    "debug": "4.3.1",
    "electron": "11.3.0",
    "is-interactive": "1.0.0",
    "moment": "2.29.1",
    "moment-timezone": "0.5.33",
    "p-limit": "3.1.0",
    "p-queue": "6.6.2",
    "tz-lookup": "6.1.25",
    "yargs": "16.2.0"
  },
  "devDependencies": {
    "@commitlint/cli": "12.0.1",
    "@commitlint/config-conventional": "12.0.1",
    "@types/jasmine": "3.6.4",
    "babel-eslint": "10.1.0",
    "depcheck": "1.4.0",
    "eslint": "7.21.0",
    "eslint-plugin-jsdoc": "32.2.0",
    "husky": "5.1.1",
    "jasmine": "3.6.4",
    "lint-staged": "10.5.4",
    "nyc": "15.1.0",
    "watch": "1.0.2"
  },
  "scripts": {
    "demo": "electron ./demo.cjs",
    "start": "src/main.cjs",
    "start-gui": "electron src/main.cjs",
    "postinstall": "touch node_modules/.dependencies && husky install"
  },
  "main": "src/main.cjs",
  "type": "module",
  "nyc": {
    "all": true,
    "reporter": [
      "lcov",
      "text-summary"
    ],
    "include": [
      "file-organizer/**",
      "src/**"
    ],
    "temp-dir": "./tmp/coverage",
    "report-dir": "./tmp/unit-coverage"
  }
}
