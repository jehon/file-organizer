{
    "name": "file-organizer",
    "version": "1.0.0",
    "author": "",
    "license": "ISC",
    "dependencies": {
        "chalk": "4.1.0",
        "colors": "1.4.0",
        "command-exists": "1.2.9",
        "css-inherit": "github:jehon/css-inherit",
        "debug": "4.1.1",
        "electron": "10.0.0",
        "fs-extra": "9.0.1",
        "graceful-fs": "4.2.4",
        "is-interactive": "1.0.0",
        "moment": "2.27.0",
        "moment-timezone": "0.5.31",
        "p-limit": "3.0.2",
        "p-queue": "6.6.1",
        "shell-exec": "1.0.2",
        "tz-lookup": "6.1.25",
        "watch": "1.0.2",
        "yargs": "15.4.1"
    },
    "devDependencies": {
        "current-git-branch": "1.1.0",
        "depcheck": "1.2.0",
        "eslint": "6.8.0",
        "jasmine": "3.6.1",
        "nyc": "15.1.0"
    },
    "scripts": {
        "clean": "rm -fr tmp",
        "eslint": "eslint .",
        "eslint-fix": "eslint --fix .",
        "start": "electron file-organizer/main.js",
        "start-headless": "electron file-organizer/main.js --headless",
        "demo": "electron demo.js",
        "test": "npm run --silent test-unit && npm run --silent test-system-xvfb",
        "style": "npm run --silent eslint && npm run --silent depcheck",
        "test-unit": "nyc npm run test-unit-raw",
        "test-unit-raw": "jasmine --config=test/unit/jasmine.json",
        "test-unit-continuously": "watch 'npm run test-unit' file-organizer test",
        "test-system": "jasmine --config=test/system/jasmine.json",
        "test-system-xvfb": "xvfb-run npm run --silent test-system",
        "depcheck": "depcheck"
    },
    "nyc": {
        "reporter": [
            "lcov",
            "text-summary"
        ],
        "temp-dir": "./tmp/coverage",
        "report-dir": "./tmp/unit-coverage"
    }
}